# Port the backend listens on
PORT=4000
# Solana RPC endpoint (devnet for this hackathon)
RPC_URL=https://api.devnet.solana.com
# Cluster label surfaced to clients / Explorer links
CLUSTER=devnet

# OpenRouter API key for the tool-calling chat agent (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Any tool-calling-capable model on OpenRouter
OPENROUTER_MODEL=openai/gpt-4o-mini
# Override only if you use a self-hosted / proxied OpenAI-compatible endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
